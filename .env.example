# Control Deck local-first defaults
#
# Copy to .env.local and adjust for your machine:
#   cp .env.example .env.local

# API protection. Leave empty only for fully local/dev use.
DECK_TOKEN=

# Core local services
AGENTGO_URL=http://127.0.0.1:4243
AGENTGO_HEALTH_URL=http://127.0.0.1:4243/health
TOOL_BRIDGE_URL=http://127.0.0.1:3333/api/tools/bridge
TERMINAL_SERVICE_URL=http://127.0.0.1:4010
SEARXNG_URL=http://127.0.0.1:8888
OLLAMA_URL=http://127.0.0.1:11434

# Primary text provider
# Use provider ids from lib/llm/providers.ts:
# openai | anthropic | google | deepseek | openrouter | huggingface
# ollama | llama_server | vllm | lmstudio | custom
LLM_PROVIDER=ollama
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=

# Optional task-specific slots
LLM_FAST_PROVIDER=
LLM_FAST_BASE_URL=
LLM_FAST_MODEL=
LLM_FAST_API_KEY=

LLM_VISION_PROVIDER=
LLM_VISION_BASE_URL=
LLM_VISION_MODEL=
LLM_VISION_API_KEY=

LLM_EMBEDDING_PROVIDER=
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_MODEL=
LLM_EMBEDDING_API_KEY=

# Provider-specific cloud keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=

# Optional OpenAI org/project metadata
LLM_ORG=
LLM_PROJECT=

# Advanced / internal (rarely needed)
# Hardware mode override: lite | power (autodetected from hardware if unset)
CONTROL_DECK_MODE=
# ComfyUI API base URL (default: http://localhost:8188)
COMFY_URL=http://127.0.0.1:8188
# Voice API base URL for STT/TTS (default: http://localhost:8000)
VOICE_API_URL=http://127.0.0.1:8000
# VectorDB base URL (default: http://localhost:4242)
VECTORDB_URL=http://127.0.0.1:4242
# Directory for agent code-exec and ComfyUI output artifacts (default: ./data/artifacts)
ARTIFACTS_DIR=
# Agent sandbox root; the agent is confined to this directory tree (default: repo root)
WORKSPACE_ROOT=
# Maximum number of agentic steps per run (default: 25)
AGENT_MAX_STEPS=25
# SQLite database path (default: ./data/deck.db in dev; ~/.local/state/control-deck/data/deck.db otherwise)
DECK_DB_PATH=
