# dependencies (bun install)
node_modules

# non-bun lockfiles (this project uses bun.lock)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Next.js build output
.next

# output
out
dist
*.tgz

# Electron build artifacts
.electron-dist/
dist-electron/

# macOS AX helper build output (regenerated by scripts/build-macos-helper.sh)
scripts/macos-ax-helper/.build/
scripts/macos-ax-helper.bin

# Windows UIA host build output (regenerated by scripts/build-win-host.cjs)
electron/resources/win/WinAutomationHost.exe
win-host/bin/
win-host/obj/

# Claude session artifacts
.claude/

# GNHF local state (not for version control)
.gnhf/

# data (local state)
data/

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo
target/
**/src-tauri/gen/
__pycache__/

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Stryker mutation testing output
.stryker-tmp/
reports/mutation/

