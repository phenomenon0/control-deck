{
  "name": "control-deck",
  "version": "0.1.0",
  "type": "module",
  "main": ".electron-dist/main.js",
  "description": "Agentic cockpit — web, terminal, and native surfaces under one shell",
  "author": "Control Deck",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3333",
    "build": "next build",
    "start": "next start -p 3333",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "terminal-service": "tsx scripts/terminal-service.ts",
    "electron:compile": "tsc -p electron/tsconfig.json && node scripts/postbuild-electron.cjs",
    "electron:macos-helper": "bash scripts/build-macos-helper.sh",
    "electron:win-host": "node scripts/build-win-host.cjs",
    "electron:dev": "bun run electron:macos-helper && bun run electron:win-host && bun run electron:compile && electron .electron-dist/main.js",
    "electron:build": "next build && node scripts/copy-native-binaries.cjs && bun run electron:win-host && bun run electron:compile",
    "electron:pack": "bun run electron:build && electron-builder --config electron-builder.yml",
    "electron:rebuild": "electron-rebuild -f -w better-sqlite3,node-pty"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.1",
    "@ai-sdk/google": "^3.0.1",
    "@ai-sdk/openai": "^3.0.1",
    "@ai-sdk/openai-compatible": "^1.0.29",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/model-viewer": "^4.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/ws": "^8.18.1",
    "@wterm/react": "^0.1.9",
    "ai": "^5.0.113",
    "better-sqlite3": "12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dbus-next": "^0.10.2",
    "duck-duck-scrape": "^2.2.7",
    "koffi": "^2.12.0",
    "lucide-react": "^0.561.0",
    "monaco-editor": "^0.55.1",
    "next": "^16.0.10",
    "node-pty": "^1.1.0",
    "node-screenshots": "^0.2.1",
    "onnxruntime-node": "^1.23.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.33.5",
    "smplr": "^0.20.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tone": "^15.1.22",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.4",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "koffi",
    "onnxruntime-node"
  ]
}
